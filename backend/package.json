{
  "name": "@rocket/backend",
  "version": "0.0.1",
  "private": true,
  "description": "Rocket backend — NestJS API + request proxy service (independent of the frontend).",
  "packageManager": "pnpm@10.28.1",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:int": "pnpm --filter @rocket/api test:int",
    "clean": "turbo run clean && rm -rf node_modules",
    "prisma:generate": "pnpm --filter @rocket/api prisma:generate",
    "prisma:migrate": "pnpm --filter @rocket/api prisma:migrate",
    "prisma:deploy": "pnpm --filter @rocket/api prisma:deploy",
    "db:seed": "pnpm --filter @rocket/api db:seed"
  },
  "devDependencies": {
    "turbo": "^2.5.5",
    "typescript": "^5.7.3"
  }
}
