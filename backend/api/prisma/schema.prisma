// Rocket data model. Multi-tenant: Team is the top-level tenant boundary.
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TeamRole {
  OWNER
  ADMIN
  EDITOR
  VIEWER
}

enum WorkspaceVisibility {
  PERSONAL
  TEAM
  PUBLIC
}

model User {
  id            String              @id @default(cuid())
  email         String              @unique
  name          String?
  passwordHash  String?
  emailVerified DateTime?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  memberships   TeamMembership[]
  history       RequestHistory[]
  refreshTokens RefreshToken[]
  authTokens    AuthToken[]
  oauthIdentities OAuthIdentity[]
}

model OAuthIdentity {
  id                String   @id @default(cuid())
  provider          String
  providerAccountId String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId            String
  createdAt         DateTime @default(now())

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model RefreshToken {
  id        String    @id @default(cuid())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  // SHA-256 of the opaque token; the raw value lives only in the client cookie.
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

enum AuthTokenType {
  EMAIL_VERIFY
  PASSWORD_RESET
}

model AuthToken {
  id        String        @id @default(cuid())
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  tokenHash String        @unique
  type      AuthTokenType
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime      @default(now())

  @@index([userId])
}

model Team {
  id          String           @id @default(cuid())
  name        String
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  memberships TeamMembership[]
  workspaces  Workspace[]
  invitations Invitation[]
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  REVOKED
}

model Invitation {
  id          String           @id @default(cuid())
  team        Team             @relation(fields: [teamId], references: [id], onDelete: Cascade)
  teamId      String
  email       String
  role        TeamRole         @default(VIEWER)
  tokenHash   String           @unique
  status      InvitationStatus @default(PENDING)
  invitedById String
  expiresAt   DateTime
  createdAt   DateTime         @default(now())

  @@index([teamId])
  @@index([email])
}

model TeamMembership {
  id     String   @id @default(cuid())
  user   User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String
  team   Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  teamId String
  role   TeamRole @default(VIEWER)

  @@unique([userId, teamId])
  @@index([teamId])
}

model Workspace {
  id           String              @id @default(cuid())
  team         Team                @relation(fields: [teamId], references: [id], onDelete: Cascade)
  teamId       String
  name         String
  visibility   WorkspaceVisibility @default(PERSONAL)
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  collections  Collection[]
  environments Environment[]

  @@index([teamId])
}

model Collection {
  id          String     @id @default(cuid())
  workspace   Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  workspaceId String
  name        String
  description String?
  // Variables and the folder/request tree are stored as JSON for flexibility.
  variables   Json       @default("[]")
  tree        Json       @default("[]")
  forkOf      Collection? @relation("Fork", fields: [forkOfId], references: [id])
  forkOfId    String?
  forks       Collection[] @relation("Fork")
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([workspaceId])
}

model Environment {
  id          String    @id @default(cuid())
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  workspaceId String
  name        String
  variables   Json      @default("[]")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([workspaceId])
}

model RequestHistory {
  id          String   @id @default(cuid())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String
  workspaceId String
  // Snapshot of the sent request and response metadata.
  request     Json
  responseMeta Json
  executedAt  DateTime @default(now())

  @@index([userId])
  @@index([workspaceId])
}

enum RunStatus {
  QUEUED
  RUNNING
  COMPLETED
  FAILED
}

model MockServer {
  id           String   @id @default(cuid())
  collectionId String
  workspaceId  String
  name         String
  enabled      Boolean  @default(true)
  // [{ method, path, status, contentType, body, headers? }]
  routes       Json     @default("[]")
  createdAt    DateTime @default(now())

  @@index([workspaceId])
}

model Monitor {
  id              String    @id @default(cuid())
  collectionId    String
  workspaceId     String
  userId          String
  environmentId   String?
  name            String
  intervalMinutes Int       @default(60)
  enabled         Boolean   @default(true)
  webhookUrl      String?
  lastRunAt       DateTime?
  createdAt       DateTime  @default(now())

  @@index([workspaceId])
}

model CollectionRun {
  id            String    @id @default(cuid())
  collectionId  String
  workspaceId   String
  userId        String
  environmentId String?
  monitorId     String?
  status        RunStatus @default(QUEUED)
  iterations    Int       @default(1)
  totalRequests Int       @default(0)
  passed        Int       @default(0)
  failed        Int       @default(0)
  // Aggregated per-iteration / per-request report.
  report        Json      @default("[]")
  error         String?
  startedAt     DateTime?
  finishedAt    DateTime?
  createdAt     DateTime  @default(now())

  @@index([collectionId])
  @@index([workspaceId])
  @@index([monitorId])
}
