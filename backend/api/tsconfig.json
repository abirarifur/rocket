{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "Node",
    "outDir": "./dist",
    "rootDir": "./src",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "declaration": false,
    "declarationMap": false,
    "isolatedModules": false,
    "types": ["node", "express", "multer"],
    "esModuleInterop": true
  },
  "include": ["src/**/*.ts"]
}
